Clases Auxiliares (Copia y pega esto en tu proyecto)

Necesitas esta clase para que el código funcione (es el equivalente a GestionFechas):
package simulacroParking;

import java.sql.Timestamp;

public class GestorTarifas {

    // Devuelve la hora actual
    public static Timestamp getHoraActual() {
        return new Timestamp(System.currentTimeMillis());
    }

    // Calcula el precio: 0.05 euros por segundo (para que veas subir el precio rápido al probar)
    public static float calcularImporte(Timestamp entrada, Timestamp salida) {
        long diferenciaMilis = salida.getTime() - entrada.getTime();
        long segundos = diferenciaMilis / 1000;
        return segundos * 0.05f; // 5 céntimos por segundo
    }
    
    // Formatea la fecha a texto
    public static String getTexto(Timestamp fecha) {
        return fecha.toString();
    }
}




